{
  "name": "@ecomsaas/application",
  "version": "0.1.0",
  "description": "Application layer with use cases and repository interfaces for the EcomSaaS platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ports": {
      "types": "./dist/ports.d.ts",
      "import": "./dist/ports.js",
      "require": "./dist/ports.cjs"
    },
    "./use-cases": {
      "types": "./dist/use-cases.d.ts",
      "import": "./dist/use-cases.js",
      "require": "./dist/use-cases.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ecommerce",
    "saas",
    "domain",
    "application",
    "use-cases",
    "ports"
  ],
  "dependencies": {
    "@ecomsaas/domain": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
