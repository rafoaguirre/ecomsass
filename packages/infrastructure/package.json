{
  "name": "@ecomsaas/infrastructure",
  "version": "0.1.0",
  "description": "Shared infrastructure utilities for the EcomSaaS platform",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./id-generator": {
      "types": "./dist/id-generator/index.d.ts",
      "import": "./dist/id-generator/index.js",
      "require": "./dist/id-generator/index.cjs"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js",
      "require": "./dist/logger/index.cjs"
    },
    "./secrets": {
      "types": "./dist/secrets/index.d.ts",
      "import": "./dist/secrets/index.js",
      "require": "./dist/secrets/index.cjs"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "require": "./dist/http/index.cjs"
    },
    "./cache": {
      "types": "./dist/cache/index.d.ts",
      "import": "./dist/cache/index.js",
      "require": "./dist/cache/index.cjs"
    },
    "./queue": {
      "types": "./dist/queue/index.d.ts",
      "import": "./dist/queue/index.js",
      "require": "./dist/queue/index.cjs"
    },
    "./database": {
      "types": "./dist/database/index.d.ts",
      "import": "./dist/database/index.js",
      "require": "./dist/database/index.cjs"
    },
    "./storage": {
      "types": "./dist/storage/index.d.ts",
      "import": "./dist/storage/index.js",
      "require": "./dist/storage/index.cjs"
    },
    "./tracing": {
      "types": "./dist/tracing/index.d.ts",
      "import": "./dist/tracing/index.js",
      "require": "./dist/tracing/index.cjs"
    },
    "./email": {
      "types": "./dist/email/index.d.ts",
      "import": "./dist/email/index.js",
      "require": "./dist/email/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "id-generator": [
        "./dist/id-generator/index.d.ts"
      ],
      "logger": [
        "./dist/logger/index.d.ts"
      ],
      "secrets": [
        "./dist/secrets/index.d.ts"
      ],
      "http": [
        "./dist/http/index.d.ts"
      ],
      "cache": [
        "./dist/cache/index.d.ts"
      ],
      "queue": [
        "./dist/queue/index.d.ts"
      ],
      "database": [
        "./dist/database/index.d.ts"
      ],
      "storage": [
        "./dist/storage/index.d.ts"
      ],
      "tracing": [
        "./dist/tracing/index.d.ts"
      ],
      "email": [
        "./dist/email/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ecommerce",
    "saas",
    "infrastructure",
    "utilities"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@ecomsaas/application": "workspace:*",
    "@infisical/sdk": "^5.0.0",
    "@supabase/supabase-js": "^2.103.0",
    "bullmq": "^5.73.5",
    "ioredis": "^5.10.1",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
