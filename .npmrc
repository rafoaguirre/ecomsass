# pnpm configuration for monorepo
# https://pnpm.io/npmrc
# Note: If you use npx/npm commands, you'll see warnings about unknown configs.
# These are pnpm-specific and can be safely ignored.

# Hoisting Settings
# ----------------
# Hoist all dependencies to node_modules/.pnpm for better compatibility
shamefully-hoist=false

# Hoist specific patterns to root (useful for tooling)
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*typescript*
public-hoist-pattern[]=@types/*

# Peer Dependencies
# -----------------
# Automatically install peer dependencies (reduces manual work)
auto-install-peers=true

# Don't fail on peer dependency version mismatches (important for monorepos)
strict-peer-dependencies=false

# Installation Behavior
# ---------------------
# Enable strict package installation for reproducibility
prefer-frozen-lockfile=true

# Performance
# -----------
# Use hard links instead of copying (faster installs)
package-import-method=hardlink

# Workspace Settings
# ------------------
# Link workspace packages even if version doesn't match
link-workspace-packages=true

# Prefer workspace packages over registry
prefer-workspace-packages=true

# Logging
# -------
# Show more detailed logs during operations
loglevel=info

# Registry (uncomment and configure if using private registry)
# registry=https://registry.npmjs.org/
