{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dependencies": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "out/**"],
      "persistent": false,
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "persistent": false,
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build"],
      "persistent": false,
      "cache": false
    },
    "lint:fix": {
      "persistent": false,
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    }
  }
}
