{
  "name": "ecomsaas",
  "version": "1.0.0",
  "description": "Monorepo for an ecommerce sass system powering complex interactions between vendors and customers",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dependencies": "turbo dependencies",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "audit": "pnpm audit --audit-level=moderate",
    "prepare": "husky",
    "start": "turbo start",
    "test": "turbo test",
    "full-check": "pnpm run build && turbo run lint && turbo run type-check && pnpm run test && pnpm audit"
  },
  "keywords": [
    "ecommerce",
    "saas",
    "monorepo",
    "typescript",
    "turborepo",
    "blockchain"
  ],
  "author": "rafoaguirre <https://github.com/rafoaguirre>",
  "license": "ISC",
  "packageManager": "pnpm@10.24.0",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vite": "7.3.2"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.2",
      "file-type": ">=21.3.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
