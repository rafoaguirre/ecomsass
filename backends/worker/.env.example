# ─────────────────────────────────────────────────
# Worker Environment Variables
# ─────────────────────────────────────────────────

# Redis (required — one of REDIS_URL or REDIS_HOST must be set)
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Queue name (must match the API producer)
# QUEUE_NAME=ecomsaas

# Node environment
NODE_ENV=development

# Log level (debug | info | warn | error)
LOG_LEVEL=info
