# EcomSaaS API — Required Environment Variables
# Copy to .env and fill in values.

# Supabase — get these from your project's Settings > API page
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Server
PORT=3000

# CORS — comma-separated origins allowed to call the API
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Secrets provider: 'env' (default) or 'infisical'
# SECRETS_PROVIDER=env

# ── Stripe (required for checkout & payments) ───────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_<your-test-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>

# ── Infisical (required when SECRETS_PROVIDER=infisical) ─────────────
# When enabled, Supabase keys above are loaded from Infisical at startup
# and you no longer need to set them directly in .env.
# INFISICAL_CLIENT_ID=<your-machine-identity-client-id>
# INFISICAL_CLIENT_SECRET=<your-machine-identity-client-secret>
# INFISICAL_PROJECT_ID=<your-project-id>
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_SECRET_PATH=/
# INFISICAL_SITE_URL=https://app.infisical.com

# ── Storage ──────────────────────────────────────────────────────────
# STORAGE_PROVIDER=memory  # 'memory' (default) or 's3'
# STORAGE_BUCKET=ecomsaas-products
# STORAGE_REGION=us-east-1
# STORAGE_ENDPOINT=http://localhost:9000  # MinIO local dev
# AWS_ACCESS_KEY_ID=<your-access-key-id>
# AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
# STORAGE_FORCE_PATH_STYLE=true  # Required for MinIO
# STORAGE_PUBLIC_BASE_URL=http://localhost:9000/ecomsaas-products
