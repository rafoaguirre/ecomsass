# EcomSaaS API — Required Environment Variables
# Copy to .env and fill in values.

# Supabase (local dev defaults from `supabase start`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Server
PORT=3000

# Secrets provider: 'env' (default) or 'infisical'
# SECRETS_PROVIDER=env

# ── Infisical (required when SECRETS_PROVIDER=infisical) ─────────────
# When enabled, Supabase keys above are loaded from Infisical at startup
# and you no longer need to set them directly in .env.
# INFISICAL_CLIENT_ID=<your-machine-identity-client-id>
# INFISICAL_CLIENT_SECRET=<your-machine-identity-client-secret>
# INFISICAL_PROJECT_ID=<your-project-id>
# INFISICAL_ENVIRONMENT=dev
# INFISICAL_SECRET_PATH=/
# INFISICAL_SITE_URL=https://app.infisical.com
